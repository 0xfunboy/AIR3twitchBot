# --- CoinMarketCap API keys ---
# At least one required. Add COINMARKETCAP_KEY2..N for automatic rotation
# (round-robin per request; keys hitting 429/401 are put in cooldown).
COINMARKETCAP_KEY=
COINMARKETCAP_KEY2=
COINMARKETCAP_KEY3=

# --- CoinGecko API keys (demo/free tier "CG-..." keys) ---
# Optional but recommended. Add COINGECKO_KEY2..N for rotation.
COINGECKO_KEY=
COINGECKO_KEY2=
COINGECKO_KEY3=

# --- Question schedule (minutes) — MAX must be strictly greater than MIN ---
DELTA_T_MIN_MINUTES=20
DELTA_T_MAX_MINUTES=60

# --- Handle of the agent bot tagged in every question ---
AGENT_NAME=@your_agent_handle
